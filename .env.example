# ============================================================
# Application
# ============================================================
APP_NAME=FastAPI TodoList
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ============================================================
# Authentication (JWT / Bearer token)
# ============================================================
# Change this secret in production (use a long random string)
JWT_SECRET=change-me-to-a-long-random-secret-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============================================================
# Database (MySQL)
# ============================================================
DB_DRIVER=mysql+pymysql
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=todolist

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s | %(levelname)-8s | %(name)s | %(message)s
