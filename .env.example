# ============================================================
# Application
# ============================================================
APP_NAME=FastAPI TodoList
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ============================================================
# Authentication (JWT / HttpOnly cookies)
# ============================================================
# Change this secret in production (use a long random string)
JWT_SECRET=change-me-to-a-long-random-secret-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ACCESS_TOKEN_COOKIE_NAME=access_token
REFRESH_TOKEN_COOKIE_NAME=refresh_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
# CSRF token cookie used with the X-CSRF-Token request header.
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_COOKIE_SECURE=false
CSRF_COOKIE_SAMESITE=lax
CSRF_TOKEN_EXPIRE_SECONDS=2592000

# ============================================================
# Rate limiting
# ============================================================
# Use a dedicated long random secret in production. It hashes IPs and account ids before storage.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_KEY_SECRET=change-me-to-a-long-random-rate-limit-secret
RATE_LIMIT_LOGIN_IP_LIMIT=10
RATE_LIMIT_LOGIN_IP_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_ACCOUNT_LIMIT=5
RATE_LIMIT_LOGIN_ACCOUNT_WINDOW_SECONDS=900
RATE_LIMIT_REGISTER_IP_LIMIT=5
RATE_LIMIT_REGISTER_IP_WINDOW_SECONDS=3600
RATE_LIMIT_REGISTER_ACCOUNT_LIMIT=3
RATE_LIMIT_REGISTER_ACCOUNT_WINDOW_SECONDS=3600
RATE_LIMIT_REFRESH_IP_LIMIT=30
RATE_LIMIT_REFRESH_IP_WINDOW_SECONDS=60
RATE_LIMIT_REFRESH_USER_LIMIT=20
RATE_LIMIT_REFRESH_USER_WINDOW_SECONDS=900
RATE_LIMIT_SUMMARY_IP_LIMIT=10
RATE_LIMIT_SUMMARY_IP_WINDOW_SECONDS=60
RATE_LIMIT_SUMMARY_USER_LIMIT=10
RATE_LIMIT_SUMMARY_USER_WINDOW_SECONDS=900
RATE_LIMIT_AI_IP_LIMIT=10
RATE_LIMIT_AI_IP_WINDOW_SECONDS=60
RATE_LIMIT_AI_USER_LIMIT=20
RATE_LIMIT_AI_USER_WINDOW_SECONDS=3600

# ============================================================
# Database (MySQL)
# ============================================================
DB_DRIVER=mysql+pymysql
DB_USER=root
DB_PASSWORD=.....
DB_HOST=localhost
DB_PORT=3306
DB_NAME=todolist

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s | %(levelname)-8s | %(name)s | %(message)s


# ============================================================
# Summary task watcher
# ============================================================
SUMMARY_TASK_WATCHER_INTERVAL_SECONDS=2
SUMMARY_TASK_WATCHER_BATCH_SIZE=20
SUMMARY_TASK_PROCESSING_TIMEOUT_SECONDS=300
ENABLE_SUMMARY_TASK_WATCHER_IN_API=false

# ============================================================
# AI task creation
# ============================================================
AI_PROVIDER=gemini
GEMINI_API_KEY=......
GEMINI_MODEL=gemini-3.5-flash
